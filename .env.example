# Copy to .env and fill in locally. NEVER commit real values (.env is gitignored).

# --- Supabase CLI auth & link target (cloud project) ---
# Personal access token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Project ref: the <ref> in https://<ref>.supabase.co (Project Settings > General)
SUPABASE_PROJECT_REF=
# Database password (set when the project was created; Project Settings > Database)
SUPABASE_DB_PASSWORD=

# --- Keys (Project Settings > API) ---
# Safe for frontend:
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-side ONLY (n8n writes result_summaries). Never expose to the browser:
SUPABASE_SERVICE_ROLE_KEY=

# --- Seed config ---
# Comma-separated allowed login domains (the test roster uses fakeio.eu)
ALLOWED_EMAIL_DOMAINS=dateio.eu,tapix.io,fakeio.eu

# --- Login (email magic-code auth) ---
# The login screen offers two modes (toggle): a demo person-picker and an email
# 6-digit code. The email path runs through server routes (/api/auth/send-code,
# /api/auth/verify-code) and gates on the can_login() RPC (live employee
# directory) — no hardcoded allowlist. The code is generated and emailed by
# Supabase Auth (SMTP/Resend, configured in the Supabase dashboard); there is no
# app-level RESEND_API_KEY. Supabase Auth settings to match the UI:
#   Project Settings > Auth: Email OTP length = 6 (the UI expects 6 digits)
#   Project Settings > Auth: Email OTP expiry  = your choice (demo uses 24h)
