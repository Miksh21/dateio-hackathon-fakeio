# Copy to .env and fill in locally. NEVER commit real values (.env is gitignored).

# --- Supabase CLI auth & link target (cloud project) ---
# Personal access token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# Project ref: the <ref> in https://<ref>.supabase.co (Project Settings > General)
SUPABASE_PROJECT_REF=
# Database password (set when the project was created; Project Settings > Database)
SUPABASE_DB_PASSWORD=

# --- Keys (Project Settings > API) ---
# Safe for frontend:
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-side ONLY (n8n writes result_summaries). Never expose to the browser:
SUPABASE_SERVICE_ROLE_KEY=

# --- Seed config ---
# Comma-separated allowed login domains (the test roster uses fakeio.eu)
ALLOWED_EMAIL_DOMAINS=dateio.eu,tapix.io,fakeio.eu

# --- Login (magic-code email auth) ---
# The login allowlist lives in code at apps/web/src/lib/allowlist.ts.
# The 6-digit login code is generated and emailed by Supabase Auth; email
# delivery is handled by Supabase's SMTP integration (Resend), configured in the
# Supabase dashboard (Auth > Email Templates / Project Settings > Auth > SMTP).
# There is therefore NO app-level RESEND_API_KEY — the key lives in Supabase.
# Code expiry / single-use are governed by Supabase Auth (Project Settings >
# Auth > Email OTP Expiration; set to 10 minutes / 600s for this app).

# --- RAG summarization pipeline ---
# Step 1 (embedding ingestion): text-embedding-3-small via OpenAI.
OPENAI_API_KEY=

# Step 2 (summary generation): claude-sonnet-4-6 via Anthropic.
ANTHROPIC_API_KEY=

# n8n webhook URL — set this to trigger the pipeline when a cycle is published.
# POST { "cycle_id": "<uuid>" } to this URL.
N8N_WEBHOOK_URL=
